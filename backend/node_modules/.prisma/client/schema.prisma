generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  campaigns Campaign[]
}

model Campaign {
  id       String @id @default(uuid())
  name     String
  cost     Float
  revenue  Float
  fees     Float  @default(0)
  expenses Float  @default(0)

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
